	},
	"dependencies": {
		"cookie-parser": "^1.4.7",
		"ejs": "3.1.10",
		"express": "4.22.1",
		"morgan": "1.11.0",
		"pdfkit": "0.15.0",
		"pg": "8.11.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"jest": "29.7.0",
		"supertest": "6.3.4"
	}
}
