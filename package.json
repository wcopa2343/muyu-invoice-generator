{
	"name": "muyu-invoice-generator",
	"version": "1.0.0",
	"description": "Muyu: Invoice Generator - Vanilla Node.js Express SSR",
	"main": "src/web.js",
	"scripts": {
		"start": "node src/web.js",
		"dev": "node --watch src/web.js",
		"test": "jest --coverage",
		"test:db": "docker compose up -d db_test && jest --coverage",
		"lint": "biome check .",
